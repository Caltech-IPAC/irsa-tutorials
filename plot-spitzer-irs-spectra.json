":"introduction","implicit":true,"key":"SjEy5cF0n9"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"In this tutorial we use a published sample of debris disk host stars to demonstrate how to search for and retrieve infrared spectra using IRSA’s SSA service.\nThe targets are drawn from the catalog of debris disks compiled by Mittal et al. (2015, ApJ, 798, 87), which identifies stars exhibiting infrared excesses indicative of circumstellar dust.\nDebris disks trace the remnants of planet formation and are valuable probes of disk evolution, dust composition, and dynamical interactions with planets.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"PGwavKl6oW"}],"key":"GbXFVNpndO"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Infrared spectroscopy is particularly powerful for studying debris disks because many of the diagnostic features of dust grains—such as silicate emission bands—appear at mid‑infrared wavelengths.\nThe Spitzer Infrared Spectrograph (IRS) provides sensitive, low‑ and moderate‑resolution spectra in this regime, enabling measurements of dust temperature, composition, and structure.\nQuerying the IRSA archive for Spitzer IRS observations allows us to connect published debris‑disk samples with archival spectroscopy and explore these systems in greater physical detail.","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"FtABRiJ25Q"}],"key":"QV2SukyuOJ"},{"type":"heading","depth":3,"position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Instructions","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"bK4Kg7Kpq7"}],"identifier":"instructions","label":"Instructions","html_id":"instructions","implicit":true,"key":"jGOCIxSjNz"},{"type":"paragraph","position"