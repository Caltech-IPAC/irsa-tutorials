sabs.harvard.edu/abs/2005ApJ...622..759G/abstract","key":"n7Az5Xyqnf"},{"type":"text","value":"-partitioned (order 5), ","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"zWIK93eeiA"},{"type":"link","url":"https://parquet.apache.org/","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"Apache Parquet","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"sPXND0VbXd"}],"urlSource":"https://parquet.apache.org/","key":"KwmWJOAcN1"},{"type":"text","value":" version of the ","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"rypvjKZBti"},{"type":"link","url":"https://wise2.ipac.caltech.edu/docs/release/allwise/expsup/sec1_3.html#src_cat","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"AllWISE Source Catalog","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"niRzpcvo3z"}],"urlSource":"https://wise2.ipac.caltech.edu/docs/release/allwise/expsup/sec1_3.html#src_cat","key":"tHsvjpAI2c"},{"type":"text","value":".\nThe catalog is available through the ","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"OfRvgurWaB"},{"type":"link","url":"https://registry.opendata.aws/wise-allwise/","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"AWS Open Data","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"kdY6eDNcu5"}],"urlSource":"https://registry.opendata.aws/wise-allwise/","key":"gqGM2g2h6C"},{"type":"text","value":" program, as part of the ","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"uPRJgfBS6s"},{"type":"link","url":"https://science.nasa.gov/open-science-overview","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"NASA Open-Source Science Initiative","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"RqjLQE3rMZ"}],"urlSource":"https://science.nasa.gov/open-science-overview","key":"ij8wn8FIRZ"},{"type":"text","value":".\nAccess is free and no special permissions or credentials are required.","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"z5JR0UyoaP"}],"key":"hvnaIhZkPD"},{"type":"paragraph","position":{"start":{"line":44,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Parquet is convenient for large astronomical catalogs in part because the storage format supports efficient database-style queries on the files themselves, without having to load the catalog into a database (or into memory) first.\nThe AllWISE catalog is fairly large at 340 GB.\nThe examples below demonstrate different methods that can be used to query the catalog, filtering the data and loading only the results.\nEach method accesses the parquet files a bit differently and is useful for different types of queries.","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"MRpdIx9rlq"}],"key":"z0lsAxkMsu"}],"key":"MhXmwLV7rN"},{"type":"block","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"children":[{"type":"text","value":"Imports","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"key":"tnkNSrtWX4"}],"identifier":"imports","label":"Imports","html_id":"imports","implicit":true,"key":"BJW3yiYIgw"}],"key":"nplViNyt4s"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Uncomment the next line to install dependencies if needed.\n# !pip install 'pandas>=1.5.2' 'pyarrow>=10.0.1' matplotlib hpgeom astropy","key":"RJhxrXcoqS"},{"type":"outputs","id":"WC0sNJcuKPXKlpB9E0p7V","children":[],"key":"VTXL6ORbNH"}],"key":"vzCJUDo6f6"},{"type":"block","children":[],"key":"O8g7GPwDLY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import sys\n\nimport hpgeom as hp\nimport pandas as pd\nimport pyarrow.compute as pc\nimport pyarrow.dataset as ds\nfrom astropy import units as u\nfrom astropy.coordinates import SkyCoord\nfrom matplotlib import colors\nfrom matplotlib import pyplot as plt\nfrom pyarrow.fs import S3FileSystem","key":"sl9100ajtq"},{"type":"outputs","id":"7rkCknSMSzzmukFwT42Br","children":[],"key":"YCOOdxoRF8"}],"key":"sp6QKUGAk2"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"1. Setup catalog paths and query filters","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"nQ6or28vhU"}],"identifier":"id-1-setup-catalog-paths-and-query-filters","label":"1. Setup catalog paths and query filters","html_id":"id-1-setup-catalog-paths-and-query-filters","implicit":true,"key":"uEKDNPJAmk"}],"key":"RfftvODWIL"},{"type":"block","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"text","value":"This AllWISE catalog is stored in an ","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"t48mv7fXq8"},{"type":"link","url":"https://aws.amazon.com/s3/","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"AWS S3","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"RibDjyFYp6"}],"urlSource":"https://aws.amazon.com/s3/","key":"LeUCg71PDl"},{"type":"text","value":" cloud storage bucket.\nTo connect to an S3 bucket we just need to point the reader at S3 instead of the local filesystem.\n(Here, a “reader” is a python library that reads parquet files.)\nWe’ll use ","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"gFEfEgak9m"},{"type":"link","url":"https://arrow.apache.org/docs/python/generated/pyarrow.fs.S3FileSystem.html","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"pyarrow​.fs​.S3FileSystem","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"romwlGh7ps"}],"urlSource":"https://arrow.apache.org/docs/python/generated/pyarrow.fs.S3FileSystem.html","key":"l1xEejnzKP"},{"type":"text","value":" for this because it is recognized by every reader in examples below, and we’re already using pyarrow.\n(","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"u10eDoKNGm"},{"type":"link","url":"https://s3fs.readthedocs.io/en/latest/index.html","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"s3fs","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"aJGNGiu7k1"}],"urlSource":"https://s3fs.readthedocs.io/en/latest/index.html","key":"CDE5t4jCMk"},{"type":"text","value":" is another common option.)\nTo access without credentials, we’ll use the keyword argument ","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"xbRfsCTaiR"},{"type":"inlineCode","value":"anonymous=True","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"A0iQefcD2s"},{"type":"text","value":".\nMore information about accessing S3 buckets can be found at ","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"ybUFBBVaxi"},{"type":"link","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"IRSA cloud access introduction","key":"fPD3I8ZUSq"}],"identifier":"cloud-access-intro","label":"cloud-access-intro","url":"/cloud-access-intro","internal":true,"dataUrl":"/cloud-access-intro.json","key":"Tlna001kxk"},{"type":"text","value":".","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"ffaf9XUq1m"}],"key":"WO7adNJmT8"}],"key":"v4fWjG7r2c"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"bucket = \"nasa-irsa-wise\"\nfolder = \"wise/allwise/catalogs/p3as_psd/healpix_k5\"\nparquet_root = f\"{bucket}/{folder}/wise-allwise.parquet\"\n\nfs = S3FileSystem(region=\"us-west-2\", anonymous=True)  # the bucket is in region us-west-2","key":"E0KsX6ZxOY"},{"type":"outputs","id":"_gx3RoY3U5JKZeeHSgRfu","children":[],"key":"RV0BXsU1xC"}],"key":"vcFOIQnaRb"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":92,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"text","value":"These limits will be used to query the catalog using specific filters created in examples below.\nThe Schema Access section (below) shows how to access column names and other schema information.","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"jQ4dHHAlEC"}],"key":"fkOqljlzq7"}],"key":"BEC0FshPqd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"w1mpro_min = 10.0\nra_min, ra_max = 15, 25  # deg\ndec_min, dec_max = 62, 72  # deg\npolygon_corners = [(ra_min, dec_min), (ra_min, dec_max), (ra_max, dec_max), (ra_max, dec_min)]\nradius = 5 * u.arcmin.to(u.deg)","key":"PwZQUY6Igy"},{"type":"outputs","id":"G71X5wQUfgOnzy46EAEsN","children":[],"key":"RSaWFJxbju"}],"key":"ewTZcCW9d9"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":103,"column":1},"end":{"line":106,"column":1}},"children":[{"type":"text","value":"The catalog is partitioned by HEALPix pixel index at order 5.\nQueries can be most efficient when a filter on the partition column is included, since the reader can skip those partitions entirely.\nThus, for queries that include ra/dec constraints, we can usually speed up load times significantly by including a constraint on the HEALPix order 5 pixel index.\nThe required pixel indexes can be calculated using ","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"b9FWQ5EiMP"},{"type":"link","url":"https://hpgeom.readthedocs.io/en/latest/index.html","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"children":[{"type":"text","value":"hpgeom","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"PKc7ekSLV5"}],"urlSource":"https://hpgeom.readthedocs.io/en/latest/index.html","key":"kcf02DFfbn"},{"type":"text","value":", as demonstrated here.","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"V03blRtlIX"}],"key":"YTj0sBAgn3"}],"key":"cGFj6nst5w"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"order = 5  # the catalog is partitioned by HEALPix pixel index at order 5\nnside = hp.order_to_nside(order)  # number of order 5 pixels along one side of a base pixel","key":"s16fL9GPmj"},{"type":"outputs","id":"rizr36hUAbtNpdy3MXkXM","children":[],"key":"BpfCTqrziE"}],"key":"yQHTJJezwi"},{"type":"block","children":[],"key":"dralzExnri"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# polygon search: get the set of pixel indexes that overlap the ra/dec polygon\npolygon_pixels = hp.query_polygon(\n    nside=nside,\n    a=[corner[0] for corner in polygon_corners],  # ra values\n    b=[corner[1] for corner in polygon_corners],  # dec values\n    nest=True,  # catalog uses nested ordering scheme for pixel index\n    inclusive=True,  # return all pixels that overlap with the polygon, and maybe a few more\n)\n\nprint(f\"polygon_pixels contains {len(polygon_pixels)} of a possible {hp.nside_to_npixel(nside)} pixels\")","key":"LE0Pybej0w"},{"type":"outputs","id":"5HuOCJthSlNpVnZDHfaaP","children":[],"key":"mrRfLidBR7"}],"key":"vkF7hw37nX"},{"type":"block","children":[],"key":"SlLbFQzqzC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# cone search: get the set of pixel indexes that overlap a 5' circle around the ra/dec min\ncone_pixels = hp.query_circle(\n    nside=nside,\n    a=ra_min,\n    b=dec_min,\n    radius=radius,\n    nest=True,  # catalog uses nested ordering scheme for pixel index\n    inclusive=True,  # return all pixels that overlap with the disk, and maybe a few more\n)\n\n# this can reduce the number of partitions the reader needs to look at from 12288 down to 2\nprint(f\"cone_pixels contains {len(cone_pixels)} of a possible {hp.nside_to_npixel(nside)} pixels\")","key":"dnFX1HZ6Kq"},{"type":"outputs","id":"XG3JiO-JMwuhPJDXKsBch","children":[],"key":"yKOMVly9vm"}],"key":"vRPpex4nWa"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":141,"column":1},"end":{"line":141,"column":1}},"children":[{"type":"text","value":"2. Pandas with basic filters (magnitude limit and ra/dec polygon)","position":{"start":{"line":141,"column":1},"end":{"line":141,"column":1}},"key":"zMY8alNOVy"}],"identifier":"id-2-pandas-with-basic-filters-magnitude-limit-and-ra-dec-polygon","label":"2. Pandas with basic filters (magnitude limit and ra/dec polygon)","html_id":"id-2-pandas-with-basic-filters-magnitude-limit-and-ra-dec-polygon","implicit":true,"key":"zDw66WDNd6"}],"key":"QwncpfMreH"},{"type":"block","position":{"start":{"line":143,"column":1},"end":{"line":143,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":145,"column":1},"end":{"line":146,"column":1}},"children":[{"type":"text","value":"Example 1: Load using ","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"key":"mQjHNVTkE0"},{"type":"link","url":"https://pandas.pydata.org/docs/reference/api/pandas.read_parquet.html","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"children":[{"type":"text","value":"pandas.read_parquet","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"key":"xVSAjiiceq"}],"urlSource":"https://pandas.pydata.org/docs/reference/api/pandas.read_parquet.html","key":"LW2wk5oqXe"},{"type":"text","value":".\nFilter for magnitudes above our w1mpro limit and a sky-area limited to the ra/dec polygon.","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"key":"wZtBTeglnO"}],"key":"Abm8D0q9rc"},{"type":"paragraph","position":{"start":{"line":148,"column":1},"end":{"line":150,"column":1}},"children":[{"type":"text","value":"Pandas actually uses either pyarrow or fastparquet to interact with parquet files.\nWe’ll choose pyarrow (the default).\nFor filter options, see the ","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"Kjs6BvG2G5"},{"type":"inlineCode","value":"filters","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"lZVVTLqlhW"},{"type":"text","value":" arg description in ","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"ezfsvlZfFL"},{"type":"link","url":"https://arrow.apache.org/docs/python/generated/pyarrow.parquet.ParquetDataset.html#pyarrow.parquet.ParquetDataset","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"children":[{"type":"text","value":"ParquetDataset","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"saPSDwPvUb"}],"urlSource":"https://arrow.apache.org/docs/python/generated/pyarrow.parquet.ParquetDataset.html#pyarrow.parquet.ParquetDataset","key":"fZAcTdmH6R"},{"type":"text","value":".","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"yBLKNGvZPM"}],"key":"jj4wAC4SrU"}],"key":"xiKVz1JBfM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# expect this to take 40-90 seconds\npandas_df = pd.read_parquet(\n    parquet_root,\n    filesystem=fs,\n    # columns to be returned. similar to a SQL SELECT clause.\n    columns=[\"designation\", \"ra\", \"dec\", \"w1mpro\", \"healpix_k5\"],\n    # row filters. similar to a SQL WHERE clause.\n    # tuple conditions are joined by AND (for OR, use a list of lists)\n    # supported operators: ==, !=, <, >, <=, >=, in, not in\n    filters=[\n        (\"w1mpro\", \">\", w1mpro_min),\n        (\"ra\", \">\", ra_min),\n        (\"ra\", \"<\", ra_max),\n        (\"dec\", \">\", dec_min),\n        (\"dec\", \"<\", dec_max),\n        # include filter on partition column for most efficient loading\n        (\"healpix_k5\", \"in\", polygon_pixels),\n    ],\n)\n\npandas_df.describe()","key":"ifgKLsz8LR"},{"type":"outputs","id":"FXRaVDlMd26xSGkFzB9wO","children":[],"key":"gc3KKVDtlJ"}],"key":"QZove8apiy"},{"type":"block","children":[],"key":"k2HYixzAsO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Delete pandas_df to save memory. This is useful when running on a machine with a small amount of RAM.\ndel pandas_df","key":"lyyFfG5v0X"},{"type":"outputs","id":"A20Cr8J-1jf0peSKZkO7t","children":[],"key":"x4nfLoropf"}],"key":"SXtCukAiMs"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":181,"column":1},"end":{"line":181,"column":1}},"children":[{"type":"text","value":"3. Pyarrow with advanced filters (color-color cuts for AGN)","position":{"start":{"line":181,"column":1},"end":{"line":181,"column":1}},"key":"VgzLa609lh"}],"identifier":"id-3-pyarrow-with-advanced-filters-color-color-cuts-for-agn","label":"3. Pyarrow with advanced filters (color-color cuts for AGN)","html_id":"id-3-pyarrow-with-advanced-filters-color-color-cuts-for-agn","implicit":true,"key":"fhC0O8MJRc"}],"key":"Y19YQ7WbF0"},{"type":"block","position":{"start":{"line":183,"column":1},"end":{"line":183,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":185,"column":1},"end":{"line":186,"column":1}},"children":[{"type":"text","value":"Example 2: Load using ","position":{"start":{"line":185,"column":1},"end":{"line":185,"column":1}},"key":"a37rAFRaiF"},{"type":"link","url":"https://arrow.apache.org/docs/python/generated/pyarrow.dataset.parquet_dataset.html","position":{"start":{"line":185,"column":1},"end":{"line":185,"column":1}},"children":[{"type":"text","value":"pyarrow​.dataset​.parquet​_dataset","position":{"start":{"line":185,"column":1},"end":{"line":185,"column":1}},"key":"M4oBHlaOye"}],"urlSource":"https://arrow.apache.org/docs/python/generated/pyarrow.dataset.parquet_dataset.html","key":"SdLgVEn9BN"},{"type":"text","value":" and convert to pandas.\nUseful for:","position":{"start":{"line":185,"column":1},"end":{"line":185,"column":1}},"key":"NVFQ5xHuTv"}],"key":"HOe9Bbrrtf"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":188,"column":1},"end":{"line":190,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"advanced filters that combine, compare, and/or create new columns. (this example)","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"BledItjnSq"}],"key":"IOrCmXjUM2"}],"key":"nb1Sc9E0yX"},{"type":"listItem","spread":true,"position":{"start":{"line":189,"column":1},"end":{"line":190,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"speed. This method is more efficient at “discovering” the dataset than pandas. It also provides a persistent dataset object that can be reused for future queries, where pandas must re-discover the dataset every time. (this example and Example 3)","position":{"start":{"line":189,"column":1},"end":{"line":189,"column":1}},"key":"PxghQiIxLg"}],"key":"stdDbIho2x"}],"key":"MQkgqSKA8x"}],"key":"ZY6StH3Isp"},{"type":"paragraph","position":{"start":{"line":191,"column":1},"end":{"line":192,"column":1}},"children":[{"type":"text","value":"This example filters the catalog for AGN by making cuts in color-color space using the selection limits from ","position":{"start":{"line":191,"column":1},"end":{"line":191,"column":1}},"key":"OMywo0vxl8"},{"type":"link","url":"https://arxiv.org/pdf/1208.2530.pdf","position":{"start":{"line":191,"column":1},"end":{"line":191,"column":1}},"children":[{"type":"text","value":"Mateos et al. (2012)","position":{"start":{"line":191,"column":1},"end":{"line":191,"column":1}},"key":"bJCrxbkzr3"}],"urlSource":"https://arxiv.org/pdf/1208.2530.pdf","key":"zJHsEX1FXC"},{"type":"text","value":".\nThis is a more complicated filter than in Example 1 (it requires both constructing new columns and comparing values between columns) but this load is generally faster, demonstrating the efficiency of this method.","position":{"start":{"line":191,"column":1},"end":{"line":191,"column":1}},"key":"WuTpMICeuh"}],"key":"jGSchrTzhI"},{"type":"paragraph","position":{"start":{"line":194,"column":1},"end":{"line":198,"column":1}},"children":[{"type":"text","value":"For basic info about the ","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"uy1NNY062O"},{"type":"inlineCode","value":"columns","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"RxN8GYFShc"},{"type":"text","value":" and ","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"FWmknqT61I"},{"type":"inlineCode","value":"filter","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"i89FCk8wy2"},{"type":"text","value":" arguments, see ","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"lm1EESFk4K"},{"type":"link","url":"https://arrow.apache.org/docs/python/generated/pyarrow.dataset.Scanner.html#pyarrow.dataset.Scanner.from_dataset","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"children":[{"type":"text","value":"Scanner","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"wL27vdrenp"}],"urlSource":"https://arrow.apache.org/docs/python/generated/pyarrow.dataset.Scanner.html#pyarrow.dataset.Scanner.from_dataset","key":"lFP3heH5DX"},{"type":"text","value":".\nThe construction of columns/filters is more involved than before because they must be passed as ","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"pctUNWTwOf"},{"type":"link","url":"https://arrow.apache.org/docs/python/generated/pyarrow.dataset.Expression.html#pyarrow.dataset.Expression","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"children":[{"type":"text","value":"Expressions","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"UGBBoIVDjh"}],"urlSource":"https://arrow.apache.org/docs/python/generated/pyarrow.dataset.Expression.html#pyarrow.dataset.Expression","key":"gAYYuVYVEb"},{"type":"text","value":", and all operations must be done using pyarrow.compute ","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"k7PyvTpeXy"},{"type":"link","url":"https://arrow.apache.org/docs/python/api/compute.html","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"children":[{"type":"text","value":"functions","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"CUnPYMLyHM"}],"urlSource":"https://arrow.apache.org/docs/python/api/compute.html","key":"oF5qbh6E34"},{"type":"text","value":" and ","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"duSU8ROXOW"},{"type":"inlineCode","value":"field","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"DPJ9ejxfZo"},{"type":"text","value":"s.\nThis is demonstrated below.\nNote that the catalog uses a file naming scheme called “hive”, which the reader uses to identify partitions.\nIn other examples this is recognized automatically, but here we must pass it explicitly.","position":{"start":{"line":194,"column":1},"end":{"line":194,"column":1}},"key":"rSPasqOwoV"}],"key":"ksbFLn0KUh"}],"key":"fAShgCOc4u"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# define new columns for colors W1-W2 and W3-W4\nw1w2 = pc.subtract(pc.field(\"w1mpro\"), pc.field(\"w2mpro\"))\nw3w4 = pc.subtract(pc.field(\"w3mpro\"), pc.field(\"w4mpro\"))\n\n# define the AGN locus, as in Mateos et al., 2012\nlocus = pc.multiply(pc.scalar(0.5), w3w4)","key":"C2TMjadrEX"},{"type":"outputs","id":"ptBf_3-0hTIYZWq1aSMbw","children":[],"key":"QAXK5mwVLn"}],"key":"BW99HicIKk"},{"type":"block","children":[],"key":"wAjLJOVJxM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# expect this to take 20-60 seconds.\n# notice this is generally faster than example 1 using pandas even though\n# this filter is much more complicated, highlighting the efficiency of this method.\n\n# load catalog metadata as a pyarrow dataset\npyarrow_ds = ds.parquet_dataset(f\"{parquet_root}/_metadata\", filesystem=fs, partitioning=\"hive\")\n\n# query for AGN using selection limits from Mateos et al., 2012\npyarrow_df = pyarrow_ds.to_table(\n    # column filter. similar to a SQL SELECT clause.\n    columns={\n        \"w1w2\": w1w2,\n        \"w3w4\": w3w4,\n        \"cntr\": pc.field(\"cntr\"),\n        \"ra\": pc.field(\"ra\"),\n        \"dec\": pc.field(\"dec\"),\n        \"healpix_k5\": pc.field(\"healpix_k5\"),\n    },\n    # row filter. similar to a SQL WHERE clause.\n    filter=(\n        # color-color cuts\n        (w1w2 < pc.add(locus, pc.scalar(0.979)))\n        & (w1w2 > pc.subtract(locus, pc.scalar(0.405)))\n        & (w3w4 > pc.scalar(1.76))\n        # to do an all-sky search, comment out the rest of the filter. expect it to take 30-60 min\n        # same ra/dec polygon as before\n        & (pc.field(\"ra\") > ra_min)\n        & (pc.field(\"ra\") < ra_max)\n        & (pc.field(\"dec\") > dec_min)\n        & (pc.field(\"dec\") < dec_max)\n        # same partition-column filter as before\n        & (pc.field(\"healpix_k5\").isin(polygon_pixels))\n    ),\n).to_pandas()","key":"C7Bz8LLGdq"},{"type":"outputs","id":"Z6GsTEoA8CSHnIQU8S0S0","children":[],"key":"nKMZ8Z61xG"}],"key":"BekhLUQtnb"},{"type":"block","children":[],"key":"dgfZEL0ftc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"len(pyarrow_df.index)","key":"giJxEoBlMd"},{"type":"outputs","id":"o3AY0ErsCgDd_lx4dVb_x","children":[],"key":"pMgGYPJ7yu"}],"key":"ECVePGFoLv"},{"type":"block","children":[],"key":"DurENIW4Nn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"colorbar_norm = colors.LogNorm(vmin=1, vmax=10)  # for an all-sky search, use vmax=100_000\npyarrow_df.plot.hexbin(\"w3w4\", \"w1w2\", norm=colorbar_norm)","key":"jn5BSRDfiv"},{"type":"outputs","id":"gn4DuJcK8N6IoKjTq5HHU","children":[],"key":"HZ9pNaevB5"}],"key":"hFC1ng6vBf"},{"type":"block","children":[],"key":"QZIdBa8Lhu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Delete variables to save memory. This is useful when running on a machine with a small amount of RAM.\ndel pyarrow_ds\ndel pyarrow_df","key":"WofBMRFgtz"},{"type":"outputs","id":"Tz7u2y69H4hTSCpDvP4Sl","children":[],"key":"ChuZBO32QT"}],"key":"AX69IgzrBd"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":261,"column":1},"end":{"line":261,"column":1}},"children":[{"type":"text","value":"4. Nearest-neighbor search (using pyarrow and astropy)","position":{"start":{"line":261,"column":1},"end":{"line":261,"column":1}},"key":"jgg0GX3OMG"}],"identifier":"id-4-nearest-neighbor-search-using-pyarrow-and-astropy","label":"4. Nearest-neighbor search (using pyarrow and astropy)","html_id":"id-4-nearest-neighbor-search-using-pyarrow-and-astropy","implicit":true,"key":"neOrSMPzQm"}],"key":"H5kIROFhDt"},{"type":"block","position":{"start":{"line":263,"column":1},"end":{"line":263,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":265,"column":1},"end":{"line":268,"column":1}},"children":[{"type":"text","value":"Example 3: Spatial search using Astropy.\nNearest-neighbor searches and cone searches generally use the on-sky separation distance to determine the matches.\nIt would be cumbersome to construct the new column and filter on it using the methods shown above because the separation distance is a fairly complicated function of ra and dec.\nHowever, we can get pretty fast results by filtering down to the HEALPix pixels that cover the region, loading all the data in those partitions, and then using astropy to compute the separations and find the matches.","position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"key":"uV0pt51xxI"}],"key":"NVQK71bpp1"},{"type":"paragraph","position":{"start":{"line":270,"column":1},"end":{"line":273,"column":1}},"children":[{"type":"text","value":"Here, we’ll search for the 3 nearest neighbors to each of the 4 corners of our ra/dec polygon.\nWe’ll load the data with pyarrow because because it makes this query significantly faster than with pandas (see explanation in Example 2).\n(Note that astropy can also read parquet, but it can only read a single file at a time and so is less convenient.)\nWe’ll use ","position":{"start":{"line":270,"column":1},"end":{"line":270,"column":1}},"key":"zkqlh1c9pD"},{"type":"link","url":"https://docs.astropy.org/en/stable/api/astropy.coordinates.SkyCoord.html#astropy.coordinates.SkyCoord.match_to_catalog_sky","position":{"start":{"line":270,"column":1},"end":{"line":270,"column":1}},"children":[{"type":"text","value":"astropy​.coordinates​.SkyCoord​.match​_to​_catalog​_sky","position":{"start":{"line":270,"column":1},"end":{"line":270,"column":1}},"key":"lQevzTfI6N"}],"urlSource":"https://docs.astropy.org/en/stable/api/astropy.coordinates.SkyCoord.html#astropy.coordinates.SkyCoord.match_to_catalog_sky","key":"QG35vvQEDe"},{"type":"text","value":" to do the actual nearest neighbor search.","position":{"start":{"line":270,"column":1},"end":{"line":270,"column":1}},"key":"Ja91Y7SdWY"}],"key":"HbO4HFbi4p"}],"key":"lMIeoiqQW7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# construct dictionary of pixels covering a cone around each polygon corner\n# we did this once before but now we want all 4 corners\ncorner_cone_pixels = {\n    (ra, dec): hp.query_circle(nside=nside, a=ra, b=dec, radius=radius, nest=True, inclusive=True)\n    for (ra, dec) in polygon_corners\n}\ncorner_cone_pixels","key":"zm47RsaBLd"},{"type":"outputs","id":"hyAHhsy3YiLCBm3PgjcXe","children":[],"key":"scNwhtxeYc"}],"key":"IXHZdsNKEA"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":285,"column":1},"end":{"line":285,"column":1}},"children":[{"type":"text","value":"Find the 3 nearest neighbors of each corner:","position":{"start":{"line":285,"column":1},"end":{"line":285,"column":1}},"key":"rSuNwzMOEm"}],"key":"SdLUmliro1"}],"key":"gOSMFDSUuI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# expect this to take 30-60 seconds\nidcol = \"cntr\"\nneighbor_ids = []  # store the allwise source id (cntr) of each neighbor\ncorner_neighbors = {}  # record neighbor info for each corner (for reference. not actually used)\n\n# use same pyarrow dataset as before, but get it again to include the load time in this cell\npyarrow_ds = ds.parquet_dataset(f\"{parquet_root}/_metadata\", filesystem=fs, partitioning=\"hive\")\n\nfor (ra, dec), cone_pixels in corner_cone_pixels.items():\n\n    # load data from all pixels/partitions/files covering this corner\n    src_tbl = pyarrow_ds.to_table(\n        columns=[idcol, \"ra\", \"dec\"], filter=(pc.field(\"healpix_k5\").isin(cone_pixels))\n    )\n\n    # get list of 3 nearest neighbors to this corner\n    corner = SkyCoord(ra=ra * u.degree, dec=dec * u.degree)\n    allwise_sources = SkyCoord(ra=src_tbl[\"ra\"] * u.degree, dec=src_tbl[\"dec\"] * u.degree)\n    neighbors = [corner.match_to_catalog_sky(allwise_sources, nthneighbor=i) for i in range(1, 4)]\n\n    # get the allwise source ids. record/report some info\n    corner_neighbors[(ra, dec)] = []\n    for n, (idx, sep, _) in enumerate(neighbors):\n        srcid = src_tbl[idcol][idx.item()].as_py()\n        neighbor_ids.append(srcid)\n        corner_neighbors[(ra, dec)].append((srcid, sep))\n        print(f\"neighbor {n+1}, corner ({ra}, {dec}): {srcid} at on-sky dist {sep.to('arcsec')}\")\n\nneighbor_ids","key":"D1RKFaDORw"},{"type":"outputs","id":"GAlwXDjuC9AV76tPv7JHe","children":[],"key":"C153KCLyVh"}],"key":"krdduoQ72f"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":319,"column":1},"end":{"line":319,"column":1}},"children":[{"type":"text","value":"Load all the data (all columns) for all nearest neighbors:","position":{"start":{"line":319,"column":1},"end":{"line":319,"column":1}},"key":"yyqy9OMOPX"}],"key":"rYYl6TpTxx"}],"key":"Jr9jYjaPFE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# expect this to take 15-25 seconds\ncone_pixels = [pixel for cone_pixels in corner_cone_pixels.values() for pixel in cone_pixels]\nneighbors_df = pyarrow_ds.to_table(\n    filter=((pc.field(idcol).isin(neighbor_ids)) & (pc.field(\"healpix_k5\").isin(cone_pixels)))\n).to_pandas()\n\nneighbors_df","key":"P7sjyDkWIz"},{"type":"outputs","id":"0TyMiAI_sEYG7F50S9WFg","children":[],"key":"jBERqumpnV"}],"key":"ONHHxujgDg"},{"type":"block","children":[],"key":"xBucaKZExp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Delete variables to save memory. This is useful when running on a machine with a small amount of RAM.\ndel pyarrow_ds\ndel neighbors_df","key":"EbYfoKhRrB"},{"type":"outputs","id":"XTBr9sL5PBGuiVjnr0xq0","children":[],"key":"DyDgOUMCJF"}],"key":"Zje3QdXERB"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":337,"column":1},"end":{"line":337,"column":1}},"children":[{"type":"text","value":"5. Schema Access","position":{"start":{"line":337,"column":1},"end":{"line":337,"column":1}},"key":"ZApJbWIBFZ"}],"identifier":"id-5-schema-access","label":"5. Schema Access","html_id":"id-5-schema-access","implicit":true,"key":"BGR2It6tVy"}],"key":"GTLqXkk4xw"},{"type":"block","position":{"start":{"line":339,"column":1},"end":{"line":339,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":341,"column":1},"end":{"line":344,"column":1}},"children":[{"type":"text","value":"The schema can be viewed ","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"alKwxXof8J"},{"type":"link","url":"http://wise2.ipac.caltech.edu/docs/release/allwise/expsup/sec2_1a.html","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"children":[{"type":"text","value":"online","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"xvczH7eIc0"}],"urlSource":"http://wise2.ipac.caltech.edu/docs/release/allwise/expsup/sec2_1a.html","key":"Ih86TsuB0L"},{"type":"text","value":" and also accessed from the parquet catalog itself.\nThe example below loads it using the ","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"NoYxccQgF0"},{"type":"inlineCode","value":"_common_metadata","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"bPTjVyfnam"},{"type":"text","value":" file and ","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"xS0o9sFqiI"},{"type":"link","url":"https://arrow.apache.org/docs/python/generated/pyarrow.dataset.parquet_dataset.html","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"children":[{"type":"text","value":"pyarrow​.dataset​.parquet​_dataset","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"MWorpf9JCY"}],"urlSource":"https://arrow.apache.org/docs/python/generated/pyarrow.dataset.parquet_dataset.html","key":"NYleo9GBwM"},{"type":"text","value":".\nNote that the schema can also be accessed from the metadata in the footer of each Parquet file and from the ","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"TJ3ToSE9IW"},{"type":"inlineCode","value":"_metadata","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"dIMgUZivjl"},{"type":"text","value":" file, but the method used here is generally faster and easier.\nIn addition, this ","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"swq5SWc7th"},{"type":"inlineCode","value":"_common_metadata","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"A3SJ51KS6v"},{"type":"text","value":" file has extra information (units and descriptions) stored in the custom metadata of each column.","position":{"start":{"line":341,"column":1},"end":{"line":341,"column":1}},"key":"RUGMuqueEm"}],"key":"X4xuKzNEbc"}],"key":"KxuchjKXAP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"schema = ds.parquet_dataset(f\"{parquet_root}/_common_metadata\", filesystem=fs).schema","key":"YZLZnnWzpQ"},{"type":"outputs","id":"CbcZ7WDfuND7R6WRSfdTR","children":[],"key":"Dg1zcXoRod"}],"key":"mM0fs4XUbt"},{"type":"block","children":[],"key":"PxSyf8p5tK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# access individual columns by name or index\nfld = schema.field(1)  # equivalently: fld = schema.field(\"ra\")\n\n# basic column informati